@model MiHotel.Models.HabitacionFormViewModel

@{
    ViewData["Title"] = "Crear Habitación";
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
        max-width: 700px;
    }

    .btn-guardar {
        background-color: #464482;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
    }

        .btn-guardar:hover {
            background-color: #36366b;
        }
</style>

<div class="tarjeta-contenido">

    <h3 class="mb-4">Crear nueva habitación</h3>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Mensaje
        </div>
    }

    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Número de habitación</label>
            <input asp-for="NumeroHabitacion" class="form-control" />
            <span asp-validation-for="NumeroHabitacion" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Tipo de habitación</label>
            <select asp-for="IdSubcategoria" class="form-select">
                <option value="">Seleccione un tipo</option>
                @if (ViewBag.SubcategoriasHabitacion != null)
                {
                    foreach (var item in ViewBag.SubcategoriasHabitacion)
                    {
                        <option value="@item.IdSubcategoria">@item.Nombre</option>
                    }
                }
            </select>
            <span asp-validation-for="IdSubcategoria" class="text-danger"></span>
        </div>

        <!-- CAMBIO: SE ELIMINÓ PRECIO -->

        <div class="mb-3">
            <label class="form-label">Estado</label>
            <select asp-for="IdTipoEstado" class="form-select">
                <option value="">Seleccione un estado</option>
                @if (ViewBag.EstadosHabitacion != null)
                {
                    foreach (var item in ViewBag.EstadosHabitacion)
                    {
                        <option value="@item.IdTipoEstado">@item.Estado</option>
                    }
                }
            </select>
            <span asp-validation-for="IdTipoEstado" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn-guardar">
                Guardar habitación
            </button>

            <a asp-controller="Habitaciones" asp-action="Index" class="btn btn-secondary ms-2">
                Cancelar
            </a>
        </div>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
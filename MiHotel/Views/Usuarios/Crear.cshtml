@model MiHotel.Models.UsuarioAdmin

@{
    ViewData["Title"] = "Crear Usuario";
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
        max-width: 600px;
    }

    .btn-guardar {
        background-color: #464482;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
    }

    .btn-guardar:hover {
        background-color: #36366b;
        color: white;
    }
</style>

<div class="tarjeta-contenido">

    <h3 class="mb-4">Crear usuario</h3>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Mensaje
        </div>
    }

    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Correo</label>
            <input asp-for="Correo" class="form-control" />
            <span asp-validation-for="Correo" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input asp-for="Telefono" class="form-control" id="Telefono" maxlength="9" placeholder="1234 5678" />
            <span asp-validation-for="Telefono" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input asp-for="Clave" class="form-control" />
            <span asp-validation-for="Clave" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Confirmar contraseña</label>
            <input asp-for="ConfirmarClave" class="form-control" />
            <span asp-validation-for="ConfirmarClave" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Rol</label>

            <select asp-for="IdRol" class="form-select">
                <option value="">Seleccione un rol</option>

                @if (ViewBag.Roles != null)
                {
                    foreach (var rol in ViewBag.Roles)
                    {
                        string nombreRol = rol.NombreRol?.ToString()?.Trim().ToLower() ?? "";

                        if (nombreRol != "cliente")
                        {
                            <option value="@rol.IdRol">@rol.NombreRol</option>
                        }
                    }
                }
            </select>

            <span asp-validation-for="IdRol" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Estado</label>

            <select asp-for="Estado" class="form-select">
                <option value="activo">Activo</option>
                <option value="inactivo">Inactivo</option>
            </select>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn-guardar">
                Guardar usuario
            </button>

            <a asp-controller="Usuarios" asp-action="Index" class="btn btn-secondary ms-2">
                Cancelar
            </a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function formatearTelefonoGuatemala(input) {
            input.addEventListener("input", function () {
                let valor = input.value.replace(/\D/g, "").substring(0, 8);

                if (valor.length > 4) {
                    valor = valor.substring(0, 4) + " " + valor.substring(4);
                }

                input.value = valor;
            });
        }

        formatearTelefonoGuatemala(document.getElementById("Telefono"));
    </script>
}
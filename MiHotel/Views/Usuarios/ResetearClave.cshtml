@model MiHotel.Models.ResetearClaveAdmin

@{
    ViewData["Title"] = "Resetear Contraseña";
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
        max-width: 600px;
    }

    .btn-guardar {
        background-color: #464482;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
    }

        .btn-guardar:hover {
            background-color: #36366b;
        }
</style>

<div class="tarjeta-contenido">

    <h3 class="mb-4">Restablecer contraseña</h3>

    <div class="mb-3">
        <label class="form-label">Usuario</label>
        <input class="form-control" value="@Model.NombreUsuario" readonly />
    </div>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Mensaje
        </div>
    }

    <form asp-action="ResetearClave" method="post">

        <input asp-for="IdUsuario" type="hidden" />
        <input asp-for="NombreUsuario" type="hidden" />

        <div class="mb-3">
            <label class="form-label">Nueva contraseña</label>
            <input asp-for="NuevaClave" class="form-control" />
            <span asp-validation-for="NuevaClave" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Confirmar nueva contraseña</label>
            <input asp-for="ConfirmarNuevaClave" class="form-control" />
            <span asp-validation-for="ConfirmarNuevaClave" class="text-danger"></span>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn-guardar">
                Guardar nueva contraseña
            </button>

            <a asp-controller="Usuarios" asp-action="Index" class="btn btn-secondary ms-2">
                Cancelar
            </a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
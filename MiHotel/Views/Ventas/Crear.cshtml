@{
    ViewData["Title"] = "Ventas";
    var productos = ViewBag.Productos as System.Data.DataTable;
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
    }

    .form-control-custom {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 10px 12px;
        width: 100%;
    }

    .btn-principal {
        background-color: #464482;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        border: none;
        font-weight: 500;
    }

        .btn-principal:hover {
            background-color: #36366b;
        }

    .btn-agregar {
        background-color: #4a7c59;
        color: white;
        border: none;
        padding: 8px 14px;
        border-radius: 8px;
    }

    .btn-eliminar {
        background-color: #dc3545;
        color: white;
        border: none;
        padding: 6px 10px;
        border-radius: 6px;
    }

    .tabla-custom th {
        background-color: #212529;
        color: white;
    }

    .tabla-custom td {
        vertical-align: middle;
    }
</style>

<div class="tarjeta-contenido">

    <!-- ENCABEZADO -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="m-0">Registro de Ventas</h3>
    </div>

    <form method="post">

        <!-- TABLA -->
        <div class="table-responsive">
            <table class="table table-bordered tabla-custom" id="tablaVentas">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Stock</th>
                        <th>Cantidad</th>
                        <th>Precio</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <!-- BOTÓN AGREGAR -->
        <button type="button" class="btn-agregar" onclick="agregarFila()">
            + Agregar producto
        </button>

        <!-- TOTAL -->
        <div class="mt-3 text-end">
            <strong>Total: Q <span id="totalGeneral">0.00</span></strong>
        </div>

        <!-- ACCIONES -->
        <div class="mt-4 d-flex gap-2 flex-wrap">
            <button type="submit" class="btn-principal">
                Guardar Venta
            </button>
        </div>

    </form>

</div>

<script>
    const productos = [
        @foreach (System.Data.DataRow fila in productos.Rows)
        {
                <text>
                {
                    id: @fila["id_proser"],
                    nombre: "@fila["nombre_proser"]",
                    stock: @fila["stock"],
                    precio: @fila["precio"]
                },
                </text>
        }
    ];

    function agregarFila() {
        let fila = `
        <tr>
            <td>
                <select name="idProducto" class="form-control-custom" onchange="actualizar(this)" required>
                    <option value="">Seleccione</option>
                    ${productos.map(p => `<option value="${p.id}" data-stock="${p.stock}" data-precio="${p.precio}">${p.nombre}</option>`).join('')}
                </select>
            </td>

            <td>
                <input type="text" class="form-control-custom stock" readonly>
            </td>

            <td>
                <input type="number" name="cantidad" class="form-control-custom cantidad" min="1" oninput="calcularFila(this)" required>
            </td>

            <td>
                <input type="number" name="precio" class="form-control-custom precio" readonly>
            </td>

            <td>
                <input type="text" class="form-control-custom subtotal" readonly>
            </td>

            <td>
                <button type="button" class="btn-eliminar" onclick="eliminarFila(this)">X</button>
            </td>
        </tr>
        `;

        document.querySelector("#tablaVentas tbody").insertAdjacentHTML("beforeend", fila);
    }

    function actualizar(select) {
        let option = select.options[select.selectedIndex];
        let fila = select.closest("tr");

        let stock = parseInt(option.getAttribute("data-stock")) || 0;
        let precio = parseFloat(option.getAttribute("data-precio")) || 0;

        fila.querySelector(".stock").value = stock;
        fila.querySelector(".precio").value = precio;

        calcularFila(fila.querySelector(".cantidad"));
    }

    function calcularFila(input) {
        let fila = input.closest("tr");

        let cantidad = parseInt(fila.querySelector(".cantidad").value) || 0;
        let precio = parseFloat(fila.querySelector(".precio").value) || 0;
        let stock = parseInt(fila.querySelector(".stock").value) || 0;

        if (cantidad > stock) {
            alert("Stock insuficiente");
            input.value = "";
            fila.querySelector(".subtotal").value = "";
            calcularTotal();
            return;
        }

        let subtotal = cantidad * precio;
        fila.querySelector(".subtotal").value = subtotal.toFixed(2);

        calcularTotal();
    }

    function calcularTotal() {
        let total = 0;

        document.querySelectorAll(".subtotal").forEach(el => {
            total += parseFloat(el.value) || 0;
        });

        document.getElementById("totalGeneral").innerText = total.toFixed(2);
    }

    function eliminarFila(btn) {
        btn.closest("tr").remove();
        calcularTotal();
    }
</script>
@{
    ViewData["Title"] = "Editar Subcategoría";
    var categorias = ViewBag.Categorias as System.Data.DataTable;
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
        max-width: 800px;
    }

    .form-label-custom {
        font-weight: 600;
        color: #363636;
        margin-bottom: 6px;
    }

    .form-control-custom {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 10px 12px;
        width: 100%;
    }

    .btn-actualizar {
        background-color: #824B44;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
    }

        .btn-actualizar:hover {
            background-color: #6d3f39;
        }

    .btn-volver {
        background-color: #6c757d;
        color: white;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
        display: inline-block;
    }

        .btn-volver:hover {
            background-color: #5a6268;
            color: white;
        }

    .acciones-formulario {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 20px;
    }
</style>

<div class="tarjeta-contenido">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="m-0">Editar Subcategoría</h3>
    </div>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Mensaje
        </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="id" value="@ViewBag.Id" />

        <div class="mb-3">
            <div class="form-label-custom">Nombre de la subcategoría</div>
            <input type="text"
                   name="nombre_subcategoria"
                   value="@ViewBag.Nombre"
                   class="form-control-custom"
                   required />
        </div>

        <div class="mb-3">
            <div class="form-label-custom">Categoría</div>
            <select name="id_categoria" class="form-control-custom" required>
                @foreach (System.Data.DataRow fila in categorias.Rows)
                {
                    var selected = (int)fila["id_categoria"] == (int)ViewBag.IdCategoria;

                    <option value="@fila["id_categoria"]" selected="@(selected ? "selected" : null)">
                        @fila["nombre_categoria"]
                    </option>
                }
            </select>
        </div>

        <div class="acciones-formulario">
            <button type="submit" class="btn-actualizar">
                Actualizar subcategoría
            </button>

            <a asp-action="Index" class="btn-volver">
                Volver al listado
            </a>
        </div>
    </form>

</div>
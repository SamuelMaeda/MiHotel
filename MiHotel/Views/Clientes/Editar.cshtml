@model MiHotel.Models.ClienteAdmin

@{
    ViewData["Title"] = "Crear Cliente";
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
        max-width: 850px;
    }

    .etiqueta-opcional {
        font-size: 13px;
        color: #6c757d;
        font-weight: normal;
        margin-left: 6px;
    }

    .texto-ayuda {
        font-size: 13px;
        color: #6c757d;
    }

    .btn-guardar {
        background-color: #824B44;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
    }

        .btn-guardar:hover {
            background-color: #6d3f39;
            color: white;
        }

    .btn-volver {
        background-color: #6c757d;
        color: white;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
    }

        .btn-volver:hover {
            background-color: #5a6268;
            color: white;
        }

    @@media (max-width: 768px) {
        .tarjeta-contenido {
            padding: 15px;
        }
    }
</style>

<div class="tarjeta-contenido">
    <h3 class="mb-4">Crear Cliente</h3>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">@ViewBag.Mensaje</div>
    }

    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Nit" class="form-label">
                NIT <span class="etiqueta-opcional">(Opcional)</span>
            </label>
            <input asp-for="Nit" class="form-control" />
            <span asp-validation-for="Nit" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Telefono" class="form-label"></label>
            <input asp-for="Telefono" class="form-control" placeholder="1234 5678" />
            <span asp-validation-for="Telefono" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Correo" class="form-label">
                Correo <span class="etiqueta-opcional">(Opcional)</span>
            </label>
            <input asp-for="Correo" class="form-control" />
            <span asp-validation-for="Correo" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Direccion" class="form-label">
                Dirección <span class="etiqueta-opcional">(Opcional)</span>
            </label>
            <textarea asp-for="Direccion" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Direccion" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NombreEmpresa" class="form-label">
                Nombre de empresa <span class="etiqueta-opcional">(Opcional)</span>
            </label>
            <input asp-for="NombreEmpresa" class="form-control" />
            <span asp-validation-for="NombreEmpresa" class="text-danger"></span>
        </div>

        <div class="mb-2">
            <label asp-for="NumeroEmpresa" class="form-label">
                Número de empresa <span class="etiqueta-opcional">(Opcional)</span>
            </label>
            <input asp-for="NumeroEmpresa" class="form-control" placeholder="1234 5678" />
            <span asp-validation-for="NumeroEmpresa" class="text-danger"></span>
        </div>

        <div class="mb-4 texto-ayuda">
            Si llena el nombre de empresa, también debe completar el número de empresa, y viceversa.
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn-guardar">Guardar</button>
            <a asp-action="Index" class="btn-volver">Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
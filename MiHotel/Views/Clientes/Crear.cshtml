@model MiHotel.Models.ClienteAdmin

@{
    ViewData["Title"] = "Crear Cliente";
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
    }

    .btn-guardar {
        background-color: #464482;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        border: none;
        text-decoration: none;
        font-weight: 500;
    }

        .btn-guardar:hover {
            background-color: #36366b;
            color: white;
        }

    .btn-volver {
        background-color: #824B44;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
        display: inline-block;
    }

        .btn-volver:hover {
            background-color: #6e3f39;
            color: white;
        }

    .acciones-formulario {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    @@media (max-width: 768px) {
        .tarjeta-contenido {
            padding: 15px;
        }

        .btn-guardar,
        .btn-volver {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="tarjeta-contenido">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h3 class="m-0">Nuevo Cliente</h3>
    </div>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Mensaje
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <form asp-controller="Clientes" asp-action="Crear" method="post">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Nombre" class="form-label">Nombre</label>
                <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre del cliente" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Telefono" class="form-label">Teléfono</label>
                <input asp-for="Telefono" class="form-control" maxlength="9" placeholder="1234 5678" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Nit" class="form-label">NIT</label>
                <input asp-for="Nit" class="form-control" placeholder="Opcional" />
                <span asp-validation-for="Nit" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Correo" class="form-label">Correo</label>
                <input asp-for="Correo" class="form-control" placeholder="Opcional" />
                <span asp-validation-for="Correo" class="text-danger"></span>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Direccion" class="form-label">Dirección</label>
                <input asp-for="Direccion" class="form-control" placeholder="Opcional" />
                <span asp-validation-for="Direccion" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="NombreEmpresa" class="form-label">Nombre de empresa</label>
                <input asp-for="NombreEmpresa" class="form-control" placeholder="Opcional" />
                <span asp-validation-for="NombreEmpresa" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="NumeroEmpresa" class="form-label">Número de empresa</label>
                <input asp-for="NumeroEmpresa" class="form-control" maxlength="9" placeholder="Opcional" />
                <span asp-validation-for="NumeroEmpresa" class="text-danger"></span>
            </div>
        </div>

        <div class="acciones-formulario">
            <button type="submit" class="btn-guardar">
                Guardar Cliente
            </button>

            <a asp-controller="Clientes" asp-action="Index" class="btn-volver">
                Volver al listado
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function formatearTelefono(input) {
            let valor = input.value.replace(/\D/g, "").substring(0, 8);

            if (valor.length > 4) {
                valor = valor.substring(0, 4) + " " + valor.substring(4);
            }

            input.value = valor;
        }

        const telefono = document.getElementById("Telefono");
        const numeroEmpresa = document.getElementById("NumeroEmpresa");

        if (telefono) {
            telefono.addEventListener("input", function () {
                formatearTelefono(this);
            });
        }

        if (numeroEmpresa) {
            numeroEmpresa.addEventListener("input", function () {
                formatearTelefono(this);
            });
        }
    </script>
}
@model MiHotel.Models.ClienteAdmin

@{
    ViewData["Title"] = "Registrar Cliente";
    string? returnUrl = ViewBag.ReturnUrl as string;
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
    }

    @@media (min-width: 768px) {
        .tarjeta-contenido {
            padding: 25px;
        }
    }

    .btn-guardar {
        background-color: #464482;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        border: none;
        text-decoration: none;
        font-weight: 500;
    }

        .btn-guardar:hover {
            background-color: #36366b;
            color: white;
        }

    .btn-volver {
        background-color: #824B44;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
        display: inline-block;
    }

        .btn-volver:hover {
            background-color: #6e3f39;
            color: white;
        }

    .acciones-formulario {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .mensaje-informativo {
        background-color: #E6D3D0;
        color: #363636;
        border: 1px solid #824B44;
        border-radius: 8px;
        padding: 12px 14px;
        margin-bottom: 20px;
    }
</style>

<div class="container-fluid px-3 px-md-4 py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="tarjeta-contenido">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <h3 class="m-0">Registrar Cliente</h3>
                </div>

                @if (ViewBag.Mensaje != null)
                {
                    <div class="alert alert-danger">@ViewBag.Mensaje</div>
                }

                @if (TempData["Exito"] != null)
                {
                    <div class="alert alert-success">@TempData["Exito"]</div>
                }

                @if (!string.IsNullOrWhiteSpace(returnUrl))
                {
                    <div class="mensaje-informativo">
                        Está registrando un cliente desde otro proceso del sistema. Al guardar correctamente, regresará automáticamente al formulario anterior.
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <form asp-controller="Clientes" asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    @if (!string.IsNullOrWhiteSpace(returnUrl))
                    {
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                    }

                    <div class="row">
                        <div class="col-12 col-lg-6 mb-3">
                            <label asp-for="Nombre" class="form-label">Nombre</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label asp-for="Nit" class="form-label">NIT</label>
                            <input asp-for="Nit" class="form-control" />
                            <span asp-validation-for="Nit" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label asp-for="Correo" class="form-label">Correo</label>
                            <input asp-for="Correo" class="form-control" />
                            <span asp-validation-for="Correo" class="text-danger"></span>
                        </div>

                        <div class="col-12 mb-3">
                            <label asp-for="Direccion" class="form-label">Dirección</label>
                            <input asp-for="Direccion" class="form-control" />
                            <span asp-validation-for="Direccion" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label asp-for="NombreEmpresa" class="form-label">Nombre de empresa</label>
                            <input asp-for="NombreEmpresa" class="form-control" />
                            <span asp-validation-for="NombreEmpresa" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label asp-for="NumeroEmpresa" class="form-label">Teléfono de empresa</label>
                            <input asp-for="NumeroEmpresa" class="form-control" />
                            <span asp-validation-for="NumeroEmpresa" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="acciones-formulario">
                        <button type="submit" class="btn-guardar">Guardar cliente</button>

                        @if (!string.IsNullOrWhiteSpace(returnUrl))
                        {
                            <a href="@returnUrl" class="btn-volver">Volver al formulario anterior</a>
                        }
                        else
                        {
                            <a asp-controller="Clientes" asp-action="Index" class="btn-volver">Volver al listado</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
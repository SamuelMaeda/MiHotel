@model MiHotel.Models.Permiso

@{
    ViewData["Title"] = "Crear permiso";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="mb-1">Crear permiso</h2>
        <p class="text-muted mb-0">Registra un nuevo permiso del sistema.</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-action="Crear" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="NombrePermiso" class="form-label"></label>
                    <input asp-for="NombrePermiso" class="form-control" placeholder="Ejemplo: crear_usuario" />
                    <span asp-validation-for="NombrePermiso" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Describe brevemente para qué sirve este permiso"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Guardar
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Volver
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
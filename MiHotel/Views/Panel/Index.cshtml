@{
    ViewData["Title"] = "Panel Principal";

    string nombreUsuario = ViewBag.NombreUsuario ?? "Usuario";
    string nombreRol = ViewBag.NombreRol ?? "Sin rol";
}

<style>
    .tarjeta-bienvenida {
        background-color: #DEDEDE;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.12);
        margin-bottom: 20px;
    }

    .menu-rol {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
    }

    .opcion-menu {
        background-color: #464482;
        color: white;
        padding: 12px 18px;
        border-radius: 10px;
        text-decoration: none;
        display: inline-block;
        margin: 8px 8px 0 0;
    }

        .opcion-menu:hover {
            background-color: #36366b;
            color: white;
        }
</style>

<div class="tarjeta-bienvenida">
    <h2>Bienvenido al sistema</h2>
    <p>Has iniciado sesión correctamente.</p>
</div>

<div class="menu-rol">
    <h4>Opciones disponibles</h4>

    @if (nombreRol.ToLower() == "admin")
    {
        
        <a asp-controller="Usuarios" asp-action="Index" class="opcion-menu">Usuarios</a>
        <a asp-controller="Roles" asp-action="Index" class="opcion-menu">Roles</a>
        <a asp-controller="Permisos" asp-action="Index" class="opcion-menu">Permisos</a>
        <a asp-controller="RolPermisos" asp-action="Index" class="opcion-menu">RolPermisos</a>
        <a href="#" class="opcion-menu">Inventario</a>
        <a asp-controller="Reservas" asp-action="Index" class="opcion-menu">Reservas</a>
        <a href="#" class="opcion-menu">Punto de Venta</a>
        <a href="#" class="opcion-menu">Cuentas por Cobrar</a>
        <a href="#" class="opcion-menu">Cuentas por Pagar</a>
        <a href="#" class="opcion-menu">Reportes</a>
        <a asp-controller="Habitaciones" asp-action="Index" class="opcion-menu">Habitaciones</a>
        <a asp-controller="Clientes" asp-action="Index" class="opcion-menu">Clientes</a>
        <a asp-controller="Disponibilidad" asp-action="Index" class="opcion-menu">Disponibilidad</a>
    }
    else if (nombreRol.ToLower() == "recepcionista")
    {
        <a href="#" class="opcion-menu">Reservas</a>
        <a href="#" class="opcion-menu">Check-In</a>
        <a href="#" class="opcion-menu">Check-Out</a>
        <a asp-controller="Habitaciones" asp-action="Index" class="opcion-menu">Habitaciones</a>
        <a asp-controller="Clientes" asp-action="Index" class="opcion-menu">Clientes</a>
        
    }
    else if (nombreRol.ToLower() == "camarero")
    {
        <a href="#" class="opcion-menu">Punto de Venta</a>
        <a href="#" class="opcion-menu">Restaurante</a>
        <a href="#" class="opcion-menu">Consumos</a>
    }
    else if (nombreRol.ToLower() == "cliente")
    {
        <a href="#" class="opcion-menu">Mis Reservas</a>
        <a asp-controller="Disponibilidad" asp-action="Index" class="opcion-menu">Disponibilidad</a>
        <a href="#" class="opcion-menu">Mis Pagos</a>

    }
    else
    {
        <p>No hay opciones configuradas para este rol.</p>
    }
</div>
@model System.Data.DataTable

@{
    ViewData["Title"] = "Reservas";

    string busqueda = ViewBag.Busqueda ?? "";
    string ordenarPor = ViewBag.OrdenarPor ?? "fecha_entrada";
    string direccion = ViewBag.Direccion ?? "asc";
    string vista = ViewBag.Vista ?? "pendiente";
    int paginaActual = ViewBag.PaginaActual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    int totalRegistros = ViewBag.TotalRegistros ?? 0;

    string SiguienteDireccion(string columna)
    {
        if (ordenarPor == columna && direccion == "asc")
        {
            return "desc";
        }
        return "asc";
    }

    string IconoOrden(string columna)
    {
        if (ordenarPor != columna)
        {
            return "bi-arrow-down-up";
        }
        return direccion == "asc" ? "bi-sort-alpha-down" : "bi-sort-alpha-up";
    }
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
    }

    .btn-crear {
        background-color: #464482;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
    }

    .tabs-vista {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .tab-vista {
        text-decoration: none;
        padding: 10px 14px;
        border-radius: 8px;
        background-color: #E6D3D0;
        color: #363636;
        font-weight: 500;
    }

        .tab-vista.activa {
            background-color: #824B44;
            color: white;
        }

    .paginacion {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .pagina-link {
        padding: 8px 12px;
        border-radius: 8px;
        text-decoration: none;
        background-color: #E6D3D0;
        color: #363636;
    }

        .pagina-link.activa {
            background-color: #464482;
            color: white;
            font-weight: bold;
        }

    .encabezado-orden {
        color: inherit;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
    }

    .acciones-contenedor {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-icono {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        font-size: 16px;
    }

    .btn-detalle {
        background-color: #464482;
    }

    .btn-pagos {
        background-color: #5a58a6;
    }

    .btn-editar {
        background-color: #824B44;
    }

    .btn-confirmar {
        background-color: #198754;
    }

    .btn-checkin {
        background-color: #0d6efd;
    }

    .btn-checkout {
        background-color: #fd7e14;
    }

    .btn-cancelar {
        background-color: #6e3f39;
    }

    .estado-pendiente {
        color: #856404;
        font-weight: bold;
    }

    .estado-confirmada {
        color: #0f5132;
        font-weight: bold;
    }

    .estado-en_curso {
        color: #0c5460;
        font-weight: bold;
    }

    .estado-cancelada {
        color: #842029;
        font-weight: bold;
    }

    .estado-finalizada {
        color: #0c5460;
        font-weight: bold;
    }

    .form-accion {
        display: inline;
    }
</style>

<div class="tarjeta-contenido">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h3 class="m-0">Gestión de Reservas</h3>
        <a asp-controller="Reservas" asp-action="Crear" class="btn-crear">Nueva Reserva</a>
    </div>

    <div class="tabs-vista">
        <a asp-controller="Reservas" asp-action="Index" asp-route-vista="todas" asp-route-busqueda="@busqueda" asp-route-ordenarPor="@ordenarPor" asp-route-direccion="@direccion" class="tab-vista @(vista == "todas" ? "activa" : "")">Todas</a>
        <a asp-controller="Reservas" asp-action="Index" asp-route-vista="pendiente" asp-route-busqueda="@busqueda" asp-route-ordenarPor="@ordenarPor" asp-route-direccion="@direccion" class="tab-vista @(vista == "pendiente" ? "activa" : "")">Pendientes</a>
        <a asp-controller="Reservas" asp-action="Index" asp-route-vista="confirmada" asp-route-busqueda="@busqueda" asp-route-ordenarPor="@ordenarPor" asp-route-direccion="@direccion" class="tab-vista @(vista == "confirmada" ? "activa" : "")">Confirmadas</a>
        <a asp-controller="Reservas" asp-action="Index" asp-route-vista="en_curso" asp-route-busqueda="@busqueda" asp-route-ordenarPor="@ordenarPor" asp-route-direccion="@direccion" class="tab-vista @(vista == "en_curso" ? "activa" : "")">En curso</a>
        <a asp-controller="Reservas" asp-action="Index" asp-route-vista="cancelada" asp-route-busqueda="@busqueda" asp-route-ordenarPor="@ordenarPor" asp-route-direccion="@direccion" class="tab-vista @(vista == "cancelada" ? "activa" : "")">Canceladas</a>
        <a asp-controller="Reservas" asp-action="Index" asp-route-vista="finalizada" asp-route-busqueda="@busqueda" asp-route-ordenarPor="@ordenarPor" asp-route-direccion="@direccion" class="tab-vista @(vista == "finalizada" ? "activa" : "")">Finalizadas</a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">@TempData["Exito"]</div>
    }

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-danger">@TempData["Mensaje"]</div>
    }

    <form id="formBusqueda" asp-controller="Reservas" asp-action="Index" method="get" class="mb-4">
        <input type="hidden" name="vista" value="@vista" />
        <input type="hidden" name="ordenarPor" value="@ordenarPor" />
        <input type="hidden" name="direccion" value="@direccion" />

        <label class="form-label">Buscar reserva</label>
        <input type="text" id="busqueda" name="busqueda" value="@busqueda" class="form-control" placeholder="Buscar por cliente, habitación u observaciones" />
    </form>

    <div class="mb-3">
        <strong>Total de registros:</strong> @totalRegistros
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a asp-controller="Reservas" asp-action="Index" asp-route-busqueda="@busqueda" asp-route-ordenarPor="cliente" asp-route-direccion="@SiguienteDireccion("cliente")" asp-route-vista="@vista" class="encabezado-orden">
                            Cliente <i class="bi @IconoOrden("cliente")"></i>
                        </a>
                    </th>
                    <th>Habitación</th>
                    <th>
                        <a asp-controller="Reservas" asp-action="Index" asp-route-busqueda="@busqueda" asp-route-ordenarPor="fecha_entrada" asp-route-direccion="@SiguienteDireccion("fecha_entrada")" asp-route-vista="@vista" class="encabezado-orden">
                            Entrada <i class="bi @IconoOrden("fecha_entrada")"></i>
                        </a>
                    </th>
                    <th>Salida</th>
                    <th>Total</th>
                    <th>Pago Pendiente</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center">No se encontraron reservas.</td>
                    </tr>
                }
                else
                {
                    foreach (System.Data.DataRow fila in Model.Rows)
                    {
                        string estado = fila["estado"]?.ToString()?.Trim().ToLower() ?? "";

                        <tr>
                            <td>@fila["nombre"]</td>
                            <td>@fila["habitacion"]</td>
                            <td>@Convert.ToDateTime(fila["fecha_entrada"]).ToString("dd/MM/yyyy")</td>
                            <td>@Convert.ToDateTime(fila["fecha_salida"]).ToString("dd/MM/yyyy")</td>
                            <td>Q @Convert.ToDecimal(fila["total_reserva"]).ToString("N2")</td>
                            <td>Q @Convert.ToDecimal(fila["saldo_pendiente"]).ToString("N2")</td>

                            <td>
                                @if (estado == "pendiente")
                                {
                                    <span class="estado-pendiente">Pendiente</span>
                                }
                                else if (estado == "confirmada")
                                {
                                    <span class="estado-confirmada">Confirmada</span>
                                }
                                else if (estado == "en_curso")
                                {
                                    <span class="estado-en_curso">En curso</span>
                                }
                                else if (estado == "cancelada")
                                {
                                    <span class="estado-cancelada">Cancelada</span>
                                }
                                else if (estado == "finalizada")
                                {
                                    <span class="estado-finalizada">Finalizada</span>
                                }
                            </td>

                            <td>
                                <div class="acciones-contenedor">
                                    <a asp-controller="Reservas" asp-action="Detalle" asp-route-id="@fila["id_reserva"]" class="btn-icono btn-detalle" title="Ver detalle">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>

                                    <a asp-controller="Reservas" asp-action="Pagos" asp-route-id="@fila["id_reserva"]" class="btn-icono btn-pagos" title="Ver pagos">
                                        <i class="bi bi-cash-stack"></i>
                                    </a>

                                    @if (estado == "pendiente" || estado == "confirmada")
                                    {
                                        <a asp-controller="Reservas" asp-action="Editar" asp-route-id="@fila["id_reserva"]" class="btn-icono btn-editar" title="Editar reserva">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                    }

                                    @if (estado == "pendiente")
                                    {
                                        <form asp-controller="Reservas" asp-action="Confirmar" asp-route-id="@fila["id_reserva"]" method="post" class="form-accion">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-icono btn-confirmar" title="Confirmar reserva">
                                                <i class="bi bi-check-circle-fill"></i>
                                            </button>
                                        </form>
                                    }

                                    @if (estado == "confirmada")
                                    {
                                        <form asp-controller="Reservas" asp-action="CheckIn" asp-route-id="@fila["id_reserva"]" method="post" class="form-accion">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-icono btn-checkin" title="Realizar check-in">
                                                <i class="bi bi-box-arrow-in-right"></i>
                                            </button>
                                        </form>
                                    }

                                    @if (estado == "en_curso")
                                    {
                                        <form asp-controller="Reservas" asp-action="CheckOut" asp-route-id="@fila["id_reserva"]" method="post" class="form-accion">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-icono btn-checkout" title="Realizar check-out">
                                                <i class="bi bi-box-arrow-right"></i>
                                            </button>
                                        </form>
                                    }

                                    @if (estado == "pendiente" || estado == "confirmada")
                                    {
                                        <form asp-controller="Reservas" asp-action="Cancelar" asp-route-id="@fila["id_reserva"]" method="post" class="form-accion">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-icono btn-cancelar" title="Cancelar reserva">
                                                <i class="bi bi-x-circle-fill"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (totalPaginas > 1)
    {
        <div class="paginacion">
            @for (int i = 1; i <= totalPaginas; i++)
            {
                <a asp-controller="Reservas" asp-action="Index" asp-route-busqueda="@busqueda" asp-route-ordenarPor="@ordenarPor" asp-route-direccion="@direccion" asp-route-vista="@vista" asp-route-pagina="@i" class="pagina-link @(i == paginaActual ? "activa" : "")">
                    @i
                </a>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        let temporizador;

        document.getElementById("busqueda").addEventListener("input", function () {
            clearTimeout(temporizador);
            temporizador = setTimeout(function () {
                document.getElementById("formBusqueda").submit();
            }, 350);
        });
    </script>
}
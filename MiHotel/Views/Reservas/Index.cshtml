@model System.Data.DataTable

@{
    ViewData["Title"] = "Reservas";

    string busqueda = ViewBag.Busqueda ?? "";
    string ordenarPor = ViewBag.OrdenarPor ?? "fecha_entrada";
    string direccion = ViewBag.Direccion ?? "asc";
    string vista = ViewBag.Vista ?? "pendiente";
    int paginaActual = ViewBag.PaginaActual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    int totalRegistros = ViewBag.TotalRegistros ?? 0;

    string SiguienteDireccion(string columna)
    {
        if (ordenarPor == columna && direccion == "asc")
        {
            return "desc";
        }

        return "asc";
    }

    string IconoOrden(string columna)
    {
        if (ordenarPor != columna)
        {
            return "bi-arrow-down-up";
        }

        return direccion == "asc" ? "bi-sort-alpha-down" : "bi-sort-alpha-up";
    }
}

<style>
    .tarjeta-contenido {
        background-color: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.10);
    }

    .btn-crear {
        background-color: #464482;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
    }

        .btn-crear:hover {
            background-color: #36366b;
            color: white;
        }

    .tabs-vista {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .tab-vista {
        text-decoration: none;
        padding: 10px 14px;
        border-radius: 8px;
        background-color: #E6D3D0;
        color: #363636;
        font-weight: 500;
    }

        .tab-vista.activa {
            background-color: #824B44;
            color: white;
        }

    .paginacion {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .pagina-link {
        padding: 8px 12px;
        border-radius: 8px;
        text-decoration: none;
        background-color: #E6D3D0;
        color: #363636;
    }

        .pagina-link.activa {
            background-color: #464482;
            color: white;
            font-weight: bold;
        }

    .encabezado-orden {
        color: inherit;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
    }

        .encabezado-orden:hover {
            color: inherit;
        }
</style>

<div class="tarjeta-contenido">

    <!-- ENCABEZADO -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h3 class="m-0">Gestión de Reservas</h3>

        <a asp-controller="Reservas" asp-action="Crear" class="btn-crear">
            Nueva Reserva
        </a>
    </div>

    <!-- TABS -->
    <div class="tabs-vista">
        <a asp-action="Index"
           asp-route-vista="pendiente"
           asp-route-busqueda="@busqueda"
           asp-route-ordenarPor="@ordenarPor"
           asp-route-direccion="@direccion"
           class="tab-vista @(vista == "pendiente" ? "activa" : "")">
            Pendientes
        </a>

        <a asp-action="Index"
           asp-route-vista="confirmada"
           asp-route-busqueda="@busqueda"
           asp-route-ordenarPor="@ordenarPor"
           asp-route-direccion="@direccion"
           class="tab-vista @(vista == "confirmada" ? "activa" : "")">
            Confirmadas
        </a>

        <a asp-action="Index"
           asp-route-vista="cancelada"
           asp-route-busqueda="@busqueda"
           asp-route-ordenarPor="@ordenarPor"
           asp-route-direccion="@direccion"
           class="tab-vista @(vista == "cancelada" ? "activa" : "")">
            Canceladas
        </a>

        <a asp-action="Index"
           asp-route-vista="finalizada"
           asp-route-busqueda="@busqueda"
           asp-route-ordenarPor="@ordenarPor"
           asp-route-direccion="@direccion"
           class="tab-vista @(vista == "finalizada" ? "activa" : "")">
            Finalizadas
        </a>
    </div>

    <!-- MENSAJES -->
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">
            @TempData["Exito"]
        </div>
    }

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Mensaje
        </div>
    }

    <!-- BUSCADOR -->
    <form id="formBusqueda" asp-action="Index" method="get" class="mb-4">
        <input type="hidden" name="vista" value="@vista" />
        <input type="hidden" name="ordenarPor" value="@ordenarPor" />
        <input type="hidden" name="direccion" value="@direccion" />

        <label class="form-label">Buscar reserva</label>
        <input type="text"
               id="busqueda"
               name="busqueda"
               value="@busqueda"
               class="form-control"
               placeholder="Buscar por cliente o habitación" />
    </form>

    <div class="mb-3">
        <strong>Total de registros:</strong> @totalRegistros
    </div>

    <!-- TABLA -->
    <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a asp-action="Index"
                           asp-route-busqueda="@busqueda"
                           asp-route-ordenarPor="cliente"
                           asp-route-direccion="@SiguienteDireccion("cliente")"
                           asp-route-vista="@vista"
                           class="encabezado-orden">
                            Cliente
                            <i class="bi @IconoOrden("cliente")"></i>
                        </a>
                    </th>

                    <th>Habitación</th>

                    <th>
                        <a asp-action="Index"
                           asp-route-busqueda="@busqueda"
                           asp-route-ordenarPor="fecha_entrada"
                           asp-route-direccion="@SiguienteDireccion("fecha_entrada")"
                           asp-route-vista="@vista"
                           class="encabezado-orden">
                            Entrada
                            <i class="bi @IconoOrden("fecha_entrada")"></i>
                        </a>
                    </th>

                    <th>Salida</th>
                    <th>Estado</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center">
                            No se encontraron reservas.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (System.Data.DataRow fila in Model.Rows)
                    {
                        <tr>
                            <td>@fila["nombre"]</td>
                            <td>@fila["habitacion"]</td>
                            <td>@Convert.ToDateTime(fila["fecha_entrada"]).ToString("dd/MM/yyyy")</td>
                            <td>@Convert.ToDateTime(fila["fecha_salida"]).ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge bg-secondary">
                                    @fila["estado"]
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINACIÓN -->
    @if (totalPaginas > 1)
    {
        <div class="paginacion">
            @for (int i = 1; i <= totalPaginas; i++)
            {
                <a asp-action="Index"
                   asp-route-busqueda="@busqueda"
                   asp-route-ordenarPor="@ordenarPor"
                   asp-route-direccion="@direccion"
                   asp-route-vista="@vista"
                   asp-route-pagina="@i"
                   class="pagina-link @(i == paginaActual ? "activa" : "")">
                    @i
                </a>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        let temporizador;

        document.getElementById("busqueda").addEventListener("input", function () {
            clearTimeout(temporizador);

            temporizador = setTimeout(function () {
                document.getElementById("formBusqueda").submit();
            }, 350);
        });
    </script>
}